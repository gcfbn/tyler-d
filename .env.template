# --- Infrastructure ---
# URL for the Qdrant vector database (used by Orchestrator)
QDRANT_URL=http://qdrant:6334

# URL for the Python-based OCR service (used by Orchestrator)
OCR_URL=http://ocr:50051

# URL for the LLM Gateway service (used by Orchestrator)
LLM_GATEWAY_URL=http://llm-gateway:50053

# Dimension of the vector embeddings (must match your model)
VECTOR_DIMENSION=1024

# --- LLM Gateway Configuration ---
# Choose provider: ollama, gemini, or openai
LLM_PROVIDER=ollama

# Model for text generation
LLM_MODEL=SpeakLeash/bielik-11b-v3.0-instruct:Q4_K_M

# Model for generating embeddings
EMBEDDING_MODEL=bge-m3

# Ollama API URL (if using local provider)
OLLAMA_URL=http://ollama:11434

# --- External Provider Configuration (Optional) ---
# LLM_API_KEY=your_api_key_here
# LLM_URL=https://api.openai.com/v1
# USE_EXTERNAL_EMBEDDINGS=true

# --- Service Networking (Optional) ---
# SERVER_ADDR=0.0.0.0:50052
# OCR_PORT=50051

# --- CLI Configuration ---
# TYLERD_URL=http://localhost:50052
